# ============================================
# Voya MVP · Variables de entorno
# ============================================
# Copia este archivo como .env.local y rellena los valores
# NUNCA subas .env.local a GitHub
# ============================================

# Supabase
# Encuentra estos valores en: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# Anthropic (Claude AI)
# REQUERIDO desde el bloque 3 — para generar actividades
# Obtén tu key en: https://console.anthropic.com/settings/keys
# Te dan $5 USD gratis al registrarte (alcanza para ~500 generaciones)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
